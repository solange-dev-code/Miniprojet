{% extends 'admin/base.html.twig' %}

{% block title %}Modifier l'Événement - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    {# En-tête de page #}
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Gestion des Événements</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                    <li class="breadcrumb-item active">Modifier</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Retour à la liste
        </a>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-pencil-square me-2"></i>Modifier : {{ evenement.titre }}
            </h5>
            {# Inclusion du bouton de suppression rouge #}
            {{ include('admin/evenement/_delete_form.html.twig') }}
        </div>
        <div class="card-body p-4">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold text-dark">Titre de l'événement</label>
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Ex: Conférence IA'}}) }}
                        <div class="text-danger small">{{ form_errors(form.titre) }}</div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-bold text-dark">Date et Heure</label>
                        {{ form_widget(form.date, {'attr': {'class': 'form-control rounded-pill'}}) }}
                        <div class="text-danger small">{{ form_errors(form.date) }}</div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark">Description</label>
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '5', 'placeholder': 'Détails de l\'événement...'}}) }}
                        <div class="text-danger small">{{ form_errors(form.description) }}</div>
                    </div>

                    {# Pour gérer les relations (participants) si elles sont dans ton formulaire #}
                    {{ form_rest(form) }}
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-save me-1"></i> Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_evenement_index') }}" class="btn btn-light rounded-pill px-4">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}