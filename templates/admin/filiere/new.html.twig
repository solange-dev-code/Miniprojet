{% extends 'admin/base.html.twig' %}

{% block title %}Ajouter une Filière - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des filières</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Dashboard</a></li>
                <li class="breadcrumb-item active">Filières</li>
            </ol>
        </nav>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header py-3 bg-white">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-plus-circle me-2"></i>Ajouter une nouvelle filière
            </h5>
        </div>
        <div class="card-body p-4">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nom de la filière</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Ex: Génie Logiciel'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Code</label>
                        {{ form_widget(form.code, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Ex: GL'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Niveau</label>
                        {{ form_widget(form.niveau, {'attr': {'class': 'form-select rounded-pill'}}) }}
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Établissement</label>
                        {{ form_widget(form.etablissement, {'attr': {'class': 'form-select rounded-pill'}}) }}
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-bold">Statut</label>
                        {{ form_widget(form.statut, {'attr': {'class': 'form-select rounded-pill'}}) }}
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-check-circle me-1"></i> Enregistrer
                    </button>
                    <a href="{{ path('app_filiere_index') }}" class="btn btn-light rounded-pill px-4">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}