{% extends 'admin/base.html.twig' %}

{% block title %}{{ page_title }}{% endblock %}

{% block body %}
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active text-primary fw-bold">Dashboard</li>
        </ol>
    </nav>

    <div class="row g-4 mb-4">
        <!-- Carte Filières -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#e8f0fe;">
                        <i class="bi bi-journal-bookmark-fill fs-4" style="color:#4154f1;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">{{ countFilieres }}</h3>
                        <span class="text-muted" style="font-size:13px;">Filières</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte Établissements -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#e8f8f0;">
                        <i class="bi bi-building fs-4" style="color:#2eca6a;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">{{ countEtablissements }}</h3>
                        <span class="text-muted" style="font-size:13px;">Établissements</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte Utilisateurs -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#fff3e0;">
                        <i class="bi bi-people-fill fs-4" style="color:#ff771d;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">{{ countUtilisateurs }}</h3>
                        <span class="text-muted" style="font-size:13px;">Utilisateurs</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Carte Visites -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#fce4ec;">
                        <i class="bi bi-graph-up-arrow fs-4" style="color:#e91e63;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">{{ countVisites }}</h3>
                        <span class="text-muted" style="font-size:13px;">Visites ce mois</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 style="color:#012970;" class="fw-bold mb-0">Activités récentes</h5>
                </div>
                <div class="card-body px-4">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Action</th>
                                <th>Détail</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="badge bg-success rounded-pill">Ajout</span></td>
                                <td>Nouvelle filière insérée</td>
                                <td>{{ "now"|date("d/m/Y") }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 style="color:#012970;" class="fw-bold mb-0">Accès rapides</h5>
                </div>
                <div class="card-body px-4 d-flex flex-column gap-3 py-4">
                    <a href="{{ path('app_filiere_index') }}" class="btn btn-outline-primary rounded-pill text-start">
                        <i class="bi bi-journal-bookmark-fill me-2"></i>Gérer les filières
                    </a>
                    <a href="{{ path('app_etablissement_index') }}" class="btn btn-outline-success rounded-pill text-start">
                        <i class="bi bi-building me-2"></i>Gérer les établissements
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}