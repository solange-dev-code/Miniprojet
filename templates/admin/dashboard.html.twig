{# templates/admin/dashboard.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard - Administration SchoolPrepar{% endblock %}

{% block body %}

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </nav>

    <!-- Cartes statistiques -->
    <div class="row g-4 mb-4">
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#e8f0fe;">
                        <i class="bi bi-journal-bookmark-fill fs-4" style="color:#4154f1;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">24</h3>
                        <span class="text-muted" style="font-size:13px;">Filières</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#e8f8f0;">
                        <i class="bi bi-building fs-4" style="color:#2eca6a;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">87</h3>
                        <span class="text-muted" style="font-size:13px;">Établissements</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#fff3e0;">
                        <i class="bi bi-people-fill fs-4" style="color:#ff771d;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">3542</h3>
                        <span class="text-muted" style="font-size:13px;">Utilisateurs</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:55px; height:55px; background:#fce4ec;">
                        <i class="bi bi-graph-up-arrow fs-4" style="color:#e91e63;"></i>
                    </div>
                    <div>
                        <h3 class="mb-0 fw-bold" style="color:#012970;">1289</h3>
                        <span class="text-muted" style="font-size:13px;">Visites ce mois</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Activités récentes -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 style="color:#012970;" class="fw-bold mb-0">
                        <i class="bi bi-clock-history me-2"></i>Activités récentes
                    </h5>
                </div>
                <div class="card-body px-4">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Action</th>
                                <th>Détail</th>
                                <th>Date</th>
                                <th>Auteur</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="badge bg-success">Ajout</span></td>
                                <td>Filière Cybersécurité</td>
                                <td>10/04/2025</td>
                                <td>Admin</td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-warning text-dark">Modification</span></td>
                                <td>IST Lomé – contacts</td>
                                <td>09/04/2025</td>
                                <td>Admin</td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-danger">Suppression</span></td>
                                <td>Ancienne filière GRH</td>
                                <td>08/04/2025</td>
                                <td>Admin</td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-success">Ajout</span></td>
                                <td>EPC Cotonou</td>
                                <td>07/04/2025</td>
                                <td>Admin</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Accès rapides -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 style="color:#012970;" class="fw-bold mb-0">
                        <i class="bi bi-lightning-fill me-2"></i>Accès rapides
                    </h5>
                </div>
                <div class="card-body px-4 d-flex flex-column gap-2">
                    <a href="{{ path('admin_filieres_list') }}" class="btn btn-outline-primary w-100 text-start">
                        <i class="bi bi-journal-bookmark-fill me-2"></i>Gérer les filières
                    </a>
                    <a href="{{ path('admin_etablissements_list') }}" class="btn btn-outline-success w-100 text-start">
                        <i class="bi bi-building me-2"></i>Gérer les établissements
                    </a>
                    <a href="{{ path('home') }}" target="_blank" class="btn btn-outline-secondary w-100 text-start">
                        <i class="bi bi-box-arrow-up-right me-2"></i>Voir le site
                    </a>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
