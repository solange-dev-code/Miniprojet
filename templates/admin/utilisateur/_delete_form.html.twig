<form method="post" action="{{ path('app_utilisateur_delete', {'id': utilisateur.id}) }}" onsubmit="return confirm('Voulez-vous vraiment supprimer cet utilisateur ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ utilisateur.id) }}">
    <button class="btn btn-outline-danger rounded-pill px-4 shadow-sm">
        <i class="bi bi-trash me-1"></i> Supprimer le compte
    </button>
</form>