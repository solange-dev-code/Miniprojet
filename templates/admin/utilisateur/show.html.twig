{% extends 'admin/base.html.twig' %}

{% block title %}Détails Utilisateur - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    {# En-tête avec navigation #}
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Gestion des Utilisateurs</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_utilisateur_index') }}">Utilisateurs</a></li>
                    <li class="breadcrumb-item active">Profil détaillé</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_utilisateur_index') }}" class="btn btn-outline-secondary rounded-pill shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Retour
            </a>
            <a href="{{ path('app_utilisateur_edit', {'id': utilisateur.id}) }}" class="btn btn-primary rounded-pill shadow-sm">
                <i class="bi bi-pencil me-1"></i> Modifier le profil
            </a>
        </div>
    </div>

    <div class="row">
        {# Colonne Profil #}
        <div class="col-xl-4 col-md-5">
            <div class="card shadow border-0 mb-4 text-center p-4">
                <div class="mb-3">
                    <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center text-white shadow-sm" style="width: 80px; height: 80px; font-size: 2rem;">
                        {{ utilisateur.nom|first|upper }}
                    </div>
                </div>
                <h4 class="fw-bold mb-0">{{ utilisateur.nom }}</h4>
                <p class="text-muted">{{ utilisateur.email }}</p>
                <hr>
                <div class="text-start">
                    <p class="small text-uppercase fw-bold text-muted mb-1">Identifiant unique</p>
                    <p class="mb-3">#{{ utilisateur.id }}</p>

                    <p class="small text-uppercase fw-bold text-muted mb-1">Rôles système</p>
                    <span class="badge bg-light text-primary border rounded-pill px-3">Utilisateur</span>
                </div>
            </div>
        </div>

        {# Colonne Événements liés #}
        <div class="col-xl-8 col-md-7">
            <div class="card shadow border-0 mb-4">
                <div class="card-header py-3 bg-white">
                    <h5 class="m-0 fw-bold text-primary">
                        <i class="bi bi-calendar-event me-2"></i>Événements associés
                    </h5>
                </div>
                <div class="card-body">
                    {% if utilisateur.evenements|length > 0 %}
                        <div class="list-group list-group-flush">
                            {% for evenement in utilisateur.evenements %}
                                <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <h6 class="mb-0 fw-bold">{{ evenement.titre }}</h6>
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>{{ evenement.date|date('d/m/Y H:i') }}
                                        </small>
                                    </div>
                                    <a href="{{ path('app_evenement_show', {'id': evenement.id}) }}" class="btn btn-sm btn-light rounded-pill">Voir l'événement</a>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-calendar-x fs-1 text-muted d-block mb-2"></i>
                            <p class="text-muted mb-0">Aucun événement lié à cet utilisateur.</p>
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="d-flex justify-content-end">
                {# Assure-toi que ce fichier existe aussi dans admin/utilisateur/ #}
                {{ include('admin/utilisateur/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}