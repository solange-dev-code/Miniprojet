{% extends 'admin/base.html.twig' %}

{% block title %}Modifier l'utilisateur - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Utilisateurs</h1>
        <a href="{{ path('app_utilisateur_index') }}" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Retour à la liste
        </a>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-person-gear me-2"></i>Modifier le profil de : {{ utilisateur.nom }}
            </h5>
            {# Inclusion du bouton de suppression stylisé #}
            {{ include('admin/utilisateur/_delete_form.html.twig') }}
        </div>
        <div class="card-body p-4">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {% if not form.vars.valid %}
                    <div class="alert alert-danger rounded-pill px-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Veuillez corriger les erreurs ci-dessous.
                    </div>
                {% endif %}

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nom complet</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control rounded-pill'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Adresse Email</label>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control rounded-pill'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nouveau mot de passe (optionnel)</label>
                        {{ form_widget(form.password, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Laisser vide pour ne pas changer'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Événements associés</label>
                        {{ form_widget(form.evenements, {'attr': {'class': 'form-select rounded-pill'}}) }}
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-check-circle me-1"></i> Enregistrer les modifications
                    </button>
                    <a href="{{ path('app_utilisateur_index') }}" class="btn btn-light rounded-pill px-4">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}