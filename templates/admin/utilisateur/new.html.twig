{% extends 'admin/base.html.twig' %}

{% block title %}Nouvel Utilisateur - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <h1 class="h3 mb-0 text-gray-800">Gestion des Utilisateurs</h1>
    </div>

    <div class="card shadow border-0 mb-4">
        <div class="card-header py-3 bg-white">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-person-plus me-2"></i>Créer un nouvel utilisateur
            </h5>
        </div>
        <div class="card-body p-4">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {% if not form.vars.valid %}
                    <div class="alert alert-danger rounded-pill px-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Veuillez vérifier les informations du formulaire.
                    </div>
                {% endif %}

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nom complet</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Ex: Jean Dupont'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Adresse Email</label>
                        {{ form_widget(form.email, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'exemple@mail.com'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Mot de passe</label>
                        {{ form_widget(form.password, {'attr': {'class': 'form-control rounded-pill'}}) }}
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-bold">Événements</label>
                        {# C'est ici que tu verras enfin ton événement "conférence" ! #}
                        {{ form_widget(form.evenements, {'attr': {'class': 'form-select rounded-pill'}}) }}
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-check-circle me-1"></i> Créer l'utilisateur
                    </button>
                    <a href="{{ path('app_utilisateur_index') }}" class="btn btn-light rounded-pill px-4">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}