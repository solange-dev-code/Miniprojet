{# templates/admin/etablissement/index.html.twig #}
{% extends 'admin/base.html.twig' %}

{% block title %}Gestion des établissements - Admin{% endblock %}

{% block body %}

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('admin_dashboard') }}">Dashboard</a>
            </li>
            <li class="breadcrumb-item active">Établissements</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0" style="color:#012970;">
            <i class="bi bi-building me-2"></i>Gestion des établissements
        </h4>
        {# LIEN DYNAMIQUE VERS LA PAGE DE CRÉATION #}
        <a href="{{ path('app_etablissement_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Ajouter un établissement
        </a>
    </div>

    <!-- Tableau -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th class="py-3">Nom</th>
                        <th class="py-3">Ville</th>
                        <th class="py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {# BOUCLE SUR LES DONNÉES DE LA BASE #}
                    {% for etablissement in etablissements %}
                        <tr>
                            <td class="px-4">{{ etablissement.id }}</td>
                            <td class="fw-semibold">{{ etablissement.nom }}</td>
                            <td>{{ etablissement.ville }}</td>
                            <td>
                                {# LIEN VOIR #}
                                <a href="{{ path('app_etablissement_show', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-info me-1">
                                    <i class="bi bi-eye-fill"></i>
                                </a>
                                {# LIEN MODIFIER #}
                                <a href="{{ path('app_etablissement_edit', {'id': etablissement.id}) }}" class="btn btn-sm btn-outline-warning me-1">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-4">Aucun établissement enregistré pour le moment.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}