{% extends 'admin/base.html.twig' %}

{% block title %}Modifier l'Établissement - SchoolPrepar{% endblock %}

{% block body %}
<div class="container-fluid px-4">
    {# En-tête de page #}
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800">Gestion des Établissements</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_etablissement_index') }}">Établissements</a></li>
                    <li class="breadcrumb-item active">Modifier</li>
                </ol>
            </nav>
        </div>
        <a href="{{ path('app_etablissement_index') }}" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Retour à la liste
        </a>
    </div>

    {# Carte de formulaire #}
    <div class="card shadow border-0 mb-4">
        <div class="card-header py-3 bg-white d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-primary">
                <i class="bi bi-pencil-square me-2"></i>Modifier : {{ etablissement.nom }}
            </h5>
            {# Bouton de suppression stylisé #}
            {{ include('admin/etablissement/_delete_form.html.twig') }}
        </div>
        <div class="card-body p-4">
            {# Le novalidate évite les erreurs de bulles d'aide invisibles sur Windows #}
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                {% if not form.vars.valid %}
                    <div class="alert alert-danger rounded-pill px-4">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Veuillez vérifier les informations du formulaire.
                    </div>
                {% endif %}

                <div class="row g-3">
                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark">Nom de l'établissement</label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control rounded-pill', 'placeholder': 'Ex: IPNET'}}) }}
                        <div class="text-danger small">{{ form_errors(form.nom) }}</div>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-bold text-dark">Adresse complète</label>
                        {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Quartier, Rue...'}}) }}
                        <div class="text-danger small">{{ form_errors(form.adresse) }}</div>
                    </div>

                    {# Reste du formulaire (token CSRF, etc.) #}
                    {{ form_rest(form) }}
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="bi bi-save me-1"></i> Mettre à jour l'établissement
                    </button>
                    <a href="{{ path('app_etablissement_index') }}" class="btn btn-light rounded-pill px-4">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}