<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>{% block title %}Administration – SchoolPrepar{% endblock %}</title>

    <!-- Favicon -->
    <link href="{{ asset('Mentor/assets/img/favicon.png') }}" rel="icon">

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect">
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Poppins:wght@300;400;500;600;700&family=Raleway:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Vendor CSS -->
    <link href="{{ asset('Mentor/assets/vendor/bootstrap/css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('Mentor/assets/vendor/bootstrap-icons/bootstrap-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('Mentor/assets/vendor/aos/aos.css') }}" rel="stylesheet">

    <!-- Main CSS -->
    <link href="{{ asset('Mentor/assets/css/main.css') }}" rel="stylesheet">

    <style>
        body { background-color: #f8f9fa; margin: 0; padding: 0; }

        .admin-sidebar {
            min-height: 100vh;
            background: #012970;
            color: white;
            width: 260px;
            position: fixed;
            top: 0; left: 0;
            z-index: 1000;
            padding-top: 20px;
        }

        .admin-main {
            margin-left: 260px; /* Doit correspondre à la largeur de la sidebar */
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .admin-content {
            padding: 25px;
            flex-grow: 1;
        }

        /* Styles pour les liens de navigation dans la sidebar */
        .admin-sidebar .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 12px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: 0.3s;
        }

        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link.active {
            color: white;
            background: rgba(255,255,255,0.1);
        }

        .sidebar-logo {
            padding: 0 20px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 10px;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

    <!-- Barre latérale (Sidebar) -->
    {% include 'admin/partials/aside.html.twig' %}

    <div class="admin-main">

        <!-- Barre du haut (Topbar) -->
        {% include 'admin/partials/nav.html.twig' %}

        <!-- Zone de contenu dynamique -->
        <main class="admin-content">
            {% block body %}{% endblock %}
        </main>

        <!-- Pied de page (Footer) -->
        {% include 'admin/partials/footer.html.twig' %}

    </div>

    <!-- Vendor JS -->
    <script src="{{ asset('Mentor/assets/vendor/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('Mentor/assets/vendor/aos/aos.js') }}"></script>

    <!-- Main JS -->
    <script src="{{ asset('Mentor/assets/js/main.js') }}"></script>

    {% block javascripts %}{% endblock %}
</body>
</html>